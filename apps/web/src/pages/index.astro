---
import BaseLayout from '../layouts/BaseLayout.astro';
import buildCosts from '../../../../build-costs.json';

const totalCost = buildCosts.totals.estimated_cost_usd.toFixed(2);
const recentSessions = buildCosts.sessions.slice(-3).reverse();
---
<BaseLayout title="sanzh.ar — Sanzhar" description="Director of Engineering. Building tools, sharing everything.">

  <!-- Hero -->
  <section style="padding: 64px 0 80px;">
    <p style={`
      font-size: 14px;
      color: var(--accent);
      font-weight: 500;
      margin: 0 0 12px;
      letter-spacing: 0.02em;
    `}>Director of Engineering</p>
    <h1 style={`
      font-family: var(--font-heading);
      font-size: clamp(40px, 6vw, 64px);
      font-weight: 700;
      letter-spacing: -0.03em;
      line-height: 1.1;
      margin: 0 0 24px;
      color: var(--text-primary);
    `}>
      Hi, I'm Sanzhar.
    </h1>
    <p style={`
      font-size: 20px;
      line-height: 1.6;
      color: var(--text-secondary);
      max-width: 600px;
      margin: 0 0 16px;
    `}>
      I lead engineering teams and still ship code. I took a week off to build this site — a living portfolio of tools, decisions, and lessons learned.
    </p>
    <p style={`
      font-size: 15px;
      color: var(--text-tertiary);
      margin: 0;
    `}>
      Everything here is transparent: the prompts, the costs, the mistakes.
    </p>
  </section>

  <!-- Featured projects -->
  <section style="padding: 0 0 80px;">
    <h2 style={`
      font-family: var(--font-heading);
      font-size: 24px;
      font-weight: 600;
      letter-spacing: -0.02em;
      margin: 0 0 32px;
    `}>Featured projects</h2>
    <div style="display: grid; grid-template-columns: repeat(auto-fit, minmax(280px, 1fr)); gap: 20px;">
      
      <!-- Project card: This website -->
      <a href="/projects/this-website" style={`
        display: block;
        background: var(--bg-surface);
        border: 0.5px solid var(--border-default);
        border-radius: var(--radius-lg);
        padding: 24px;
        box-shadow: var(--shadow-card);
        transition: all 0.2s ease;
        color: inherit;
      `}>
        <div style={`
          height: 120px;
          background: linear-gradient(135deg, var(--accent-soft), var(--highlight-soft));
          border-radius: var(--radius-md);
          margin: 0 0 20px;
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 32px;
          color: var(--accent);
        `}>🏗️</div>
        <h3 style={`
          font-family: var(--font-heading);
          font-size: 17px;
          font-weight: 600;
          margin: 0 0 8px;
          letter-spacing: -0.01em;
        `}>This website</h3>
        <p style="font-size: 14px; color: var(--text-secondary); margin: 0 0 16px; line-height: 1.5;">
          Astro monorepo portfolio with transparent AI build costs, design system from Google Stitch, and WebAuthn auth.
        </p>
        <div style="display: flex; gap: 6px; flex-wrap: wrap;">
          <span style={`font-size: 12px; padding: 3px 10px; border-radius: var(--radius-full); background: var(--accent-soft); color: var(--accent);`}>Astro</span>
          <span style={`font-size: 12px; padding: 3px 10px; border-radius: var(--radius-full); background: var(--accent-soft); color: var(--accent);`}>React</span>
          <span style={`font-size: 12px; padding: 3px 10px; border-radius: var(--radius-full); background: var(--highlight-soft); color: var(--highlight);`}>Tailwind</span>
        </div>
      </a>

      <!-- Project card: Finance tracker -->
      <a href="/projects/finance-tracker" style={`
        display: block;
        background: var(--bg-surface);
        border: 0.5px solid var(--border-default);
        border-radius: var(--radius-lg);
        padding: 24px;
        box-shadow: var(--shadow-card);
        transition: all 0.2s ease;
        color: inherit;
      `}>
        <div style={`
          height: 120px;
          background: linear-gradient(135deg, var(--highlight-soft), var(--accent-soft));
          border-radius: var(--radius-md);
          margin: 0 0 20px;
          display: flex;
          align-items: center;
          justify-content: center;
          font-size: 32px;
        `}>💰</div>
        <h3 style={`
          font-family: var(--font-heading);
          font-size: 17px;
          font-weight: 600;
          margin: 0 0 8px;
          letter-spacing: -0.01em;
        `}>Finance tracker</h3>
        <p style="font-size: 14px; color: var(--text-secondary); margin: 0 0 16px; line-height: 1.5;">
          Personal finance dashboard with budget tracking, transaction categorization, and monthly insights.
        </p>
        <div style="display: flex; gap: 6px; flex-wrap: wrap;">
          <span style={`font-size: 12px; padding: 3px 10px; border-radius: var(--radius-full); background: var(--accent-soft); color: var(--accent);`}>React</span>
          <span style={`font-size: 12px; padding: 3px 10px; border-radius: var(--radius-full); background: var(--accent-soft); color: var(--accent);`}>Supabase</span>
          <span style={`font-size: 12px; padding: 3px 10px; border-radius: var(--radius-full); background: var(--highlight-soft); color: var(--highlight);`}>WebAuthn</span>
        </div>
      </a>

      <!-- Project card: Coming soon -->
      <div style={`
        background: var(--bg-surface);
        border: 0.5px dashed var(--border-default);
        border-radius: var(--radius-lg);
        padding: 24px;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 280px;
        color: var(--text-tertiary);
      `}>
        <p style="font-size: 14px; margin: 0;">More projects coming soon</p>
        <p style="font-size: 13px; margin: 4px 0 0; color: var(--text-tertiary);">Tennis booking · Football manager · Life dashboard</p>
      </div>

    </div>
  </section>

  <!-- Build log preview -->
  <section style="padding: 0 0 80px;">
    <div style="display: flex; align-items: baseline; justify-content: space-between; margin: 0 0 24px;">
      <h2 style={`
        font-family: var(--font-heading);
        font-size: 24px;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin: 0;
      `}>Build log</h2>
      <a href="/build-log" style="font-size: 14px;">View all →</a>
    </div>
    <div style="display: flex; flex-direction: column; gap: 12px;">
      {recentSessions.map((session) => (
        <div style={`
          display: flex;
          align-items: center;
          justify-content: space-between;
          padding: 16px 20px;
          background: var(--bg-surface);
          border: 0.5px solid var(--border-default);
          border-radius: var(--radius-md);
        `}>
          <div style="display: flex; align-items: center; gap: 16px;">
            <span style={`
              font-size: 13px;
              color: var(--text-tertiary);
              font-family: var(--font-mono);
              min-width: 90px;
            `}>{session.date}</span>
            <span style="font-size: 14px; color: var(--text-primary);">{session.description}</span>
          </div>
          <span style={`
            font-size: 13px;
            font-family: var(--font-mono);
            color: var(--highlight);
            background: var(--highlight-soft);
            padding: 2px 10px;
            border-radius: var(--radius-full);
          `}>${session.estimated_cost_usd.toFixed(2)}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- About snippet -->
  <section style="padding: 0 0 48px;">
    <div style={`
      padding: 40px;
      background: var(--bg-surface);
      border: 0.5px solid var(--border-default);
      border-radius: var(--radius-xl);
      box-shadow: var(--shadow-card);
    `}>
      <h2 style={`
        font-family: var(--font-heading);
        font-size: 24px;
        font-weight: 600;
        letter-spacing: -0.02em;
        margin: 0 0 16px;
      `}>About this project</h2>
      <p style="font-size: 16px; color: var(--text-secondary); margin: 0 0 12px; max-width: 680px;">
        I'm a Director of Engineering who took a week off to build something for myself. This site is both a portfolio and a set of tools I use daily — finance tracking, tennis court booking, football team management.
      </p>
      <p style="font-size: 16px; color: var(--text-secondary); margin: 0; max-width: 680px;">
        Every feature is documented with full transparency: the design decisions, the AI prompts I used, what they cost, and what I learned. Because the best portfolio isn't a list of things you built — it's evidence of how you think.
      </p>
    </div>
  </section>

</BaseLayout>
